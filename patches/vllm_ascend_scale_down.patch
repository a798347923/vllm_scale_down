diff --git a/vllm_ascend/distributed/parallel_state.py b/vllm_ascend/distributed/parallel_state.py
--- a/vllm_ascend/distributed/parallel_state.py	(revision 4a533861c9fcd6e181b67d7c75a037eb2898c5e0)
+++ b/vllm_ascend/distributed/parallel_state.py	(revision f357a12dd15e2dae4891cf5d26c452cc5df46641)
@@ -26,6 +26,21 @@
 
 _DYNAMIC_EPLB: GroupCoordinator | None = None
 
+_ELASTIC_INFO: torch.Tensor | None = None
+
+
+def get_elastic_info():
+    return _ELASTIC_INFO
+
+
+def set_elastic_info(elastic_info):
+    global _ELASTIC_INFO
+    if _ELASTIC_INFO is None or elastic_info is None:
+        _ELASTIC_INFO = elastic_info
